{
  "name": "kobeansql",
  "version": "1.13.6",
  "description": "A modern SQL database client with Apple glassmorphism UI",
  "main": "out/main/index.js",
  "author": {
    "name": "kobenguyent",
    "email": "kobenguyent@github.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/kobenguyent/KobeanSQL",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-builder --config.npmRebuild=false --publish never",
    "logos:crop": "node scripts/crop-logo-mark.mjs",
    "rebuild:sqlite": "electron-rebuild -f -w better-sqlite3 || echo \"better-sqlite3 rebuild skipped (using node:sqlite fallback)\"",
    "install:dev": "npm install --ignore-scripts && npm run rebuild:sqlite",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e:visualizer": "npm run build && xvfb-run -a playwright test tests/database-visualizer.spec.ts",
    "test:e2e:visualizer:update": "npm run build && xvfb-run -a playwright test tests/database-visualizer.spec.ts --update-snapshots",
    "docs:sync:check": "node scripts/check-docs-sync.mjs"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@xyflow/react": "^12.10.2",
    "better-sqlite3": "^12.10.0",
    "electron-log": "^5.4.4",
    "immer": "^11.1.8",
    "lucide-react": "^1.16.0",
    "mssql": "^12.5.4",
    "mysql2": "^3.22.4",
    "pg": "^8.21.0",
    "sql-formatter": "^15.8.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron/rebuild": "^4.0.4",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@tanstack/react-table": "^8.21.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dagre": "^0.7.54",
    "@types/mssql": "^12.3.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@uiw/react-codemirror": "^4.25.10",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "playwright": "^1.60.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.3",
    "vite": "^7.3.3",
    "vitest": "^4.1.7"
  },
  "build": {
    "appId": "com.kobenguyent.kobeansql",
    "productName": "KobeanSQL",
    "copyright": "Copyright © 2024 kobenguyent",
    "icon": "build/icon",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**",
      "build/icon.png"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "identity": "-",
      "gatekeeperAssess": false,
      "hardenedRuntime": false
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
