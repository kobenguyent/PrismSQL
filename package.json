{
  "name": "kobeansql",
  "version": "1.8.1",
  "description": "A modern SQL database client with Apple glassmorphism UI",
  "main": "out/main/index.js",
  "author": {
    "name": "kobenguyent",
    "email": "kobenguyent@github.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/kobenguyent/KobeanSQL",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-builder",
    "logos:crop": "node scripts/crop-logo-mark.mjs",
    "rebuild:sqlite": "electron-rebuild -f -w better-sqlite3",
    "install:dev": "npm install --ignore-scripts && npm run rebuild:sqlite",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e:visualizer": "npm run build && xvfb-run -a playwright test tests/database-visualizer.spec.ts",
    "test:e2e:visualizer:update": "npm run build && xvfb-run -a playwright test tests/database-visualizer.spec.ts --update-snapshots"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@xyflow/react": "^12.10.2",
    "better-sqlite3": "^9.4.3",
    "electron-log": "^5.1.2",
    "immer": "^10.0.3",
    "lucide-react": "^0.344.0",
    "mssql": "^10.0.4",
    "mysql2": "^3.9.1",
    "pg": "^8.11.3",
    "sql-formatter": "^15.8.0",
    "zustand": "^4.5.1"
  },
  "devDependencies": {
    "@codemirror/lang-sql": "^6.7.1",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@electron-toolkit/preload": "^3.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@tanstack/react-table": "^8.13.2",
    "@types/better-sqlite3": "^7.6.8",
    "@types/dagre": "^0.7.54",
    "@types/mssql": "^9.1.4",
    "@types/pg": "^8.11.2",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@uiw/react-codemirror": "^4.21.24",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^2.1.0",
    "playwright": "^1.60.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "semantic-release": "^25.0.3",
    "typescript": "^5.4.2",
    "vite": "^5.1.6",
    "vitest": "^1.4.0"
  },
  "build": {
    "appId": "com.kobenguyent.kobeansql",
    "productName": "KobeanSQL",
    "copyright": "Copyright © 2024 kobenguyent",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "identity": "-",
      "gatekeeperAssess": false,
      "hardenedRuntime": false
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
